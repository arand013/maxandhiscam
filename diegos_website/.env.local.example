# Required for the protected /admin route.
ADMIN_PASSWORD=

# Contact form delivery. Configure either SMTP_URL or the SMTP_* variables below.
SMTP_URL=
SMTP_HOST=
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=
SMTP_PASS=

# Email addresses used by the contact form.
CONTACT_FROM_EMAIL=
CONTACT_TO_EMAIL=

# Optional legacy alias for the recipient address.
CONTACT_EMAIL=
